<div class="big-container">
  <article class="article">
    <div style="width:fit-content;padding:10px; height:auto;background-color: rgb(0, 102, 255);border-radius: 10px;">
      <h3 style="text-align: center;color: #ffffff;">归档</h3>
    </div>
    <div class="topsign-title">
      <h2 class="topsign-text">文件归档</h2>
      <p style="color:var(--text-muted);">搜索文章 | 浏览论文 | 下载资料</p>
    </div>
    <script type="text/javascript" src="../js/comcode/com_artmenu.js"></script>
    <div class="sign-container">
      <div class="search" style="margin-bottom:10px;">
        <input type="text" class="searchTerm" placeholder="搜索文章..." id="inpele" style="background:var(--bg-secondary);color:var(--text-primary);border:1px solid var(--border-light);">
        <button class="searchButton" onclick="{output()}" style="background:var(--text-link);color:#fff;"><i class="fa fa-search"></i></button>
      </div>
      <div style="display:flex;justify-content:center;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px;">
        <span style="font-size:12px;color:var(--text-muted);">排序:</span>
        <button id="sort-time" onclick="sortArticles('time')" style="cursor:pointer;border:none;background:var(--text-link);color:#fff;padding:3px 12px;border-radius:12px;font-size:12px;transition:all 0.3s ease;">时间</button>
        <button id="sort-name" onclick="sortArticles('name')" style="cursor:pointer;border:none;background:var(--bg-secondary);color:var(--text-primary);padding:3px 12px;border-radius:12px;font-size:12px;transition:all 0.3s ease;">名称</button>
        <button id="sort-author" onclick="sortArticles('author')" style="cursor:pointer;border:none;background:var(--bg-secondary);color:var(--text-primary);padding:3px 12px;border-radius:12px;font-size:12px;transition:all 0.3s ease;">作者</button>
        <span style="color:var(--text-light);font-size:12px;">|</span>
        <button id="sort-asc" onclick="toggleOrder()" style="cursor:pointer;border:none;background:var(--bg-secondary);color:var(--text-primary);padding:3px 12px;border-radius:12px;font-size:12px;transition:all 0.3s ease;" title="正序/倒序">↓ 倒序</button>
      </div>
      <div style="text-align:center;margin-bottom:10px;">
        <button onclick="{searchmode = 1;document.getElementById('strict').style.color='var(--text-link)';document.getElementById('loose').style.color='var(--text-muted)';}" style="cursor:pointer;background:none;border:none;font-size:12px;padding:3px 8px;color:var(--text-link);" type="button" id="strict">严格搜索</button>
        <span style="color:var(--text-light);">|</span>
        <button onclick="{searchmode = 2;document.getElementById('loose').style.color='var(--text-link)';document.getElementById('strict').style.color='var(--text-muted)';}" style="cursor:pointer;background:none;border:none;font-size:12px;padding:3px 8px;color:var(--text-muted);" type="button" id="loose">宽泛搜索</button>
      </div>
      <div id="1">
        <ul id="article-list" style="list-style:none;padding:12px 0;"></ul>
      </div>
      <div id="3"></div>
    </div>
    <div style="display:flex;gap:20px;margin-top:20px;">
      <div class="sign-container" style="flex:1;">
        <ul class="column_box" id="like-box">
          <li class="column-title">
            <span class="at-sort b-b-ece fl"><a class="at-sort-comment-a c-666 fl" style="font-family: Georgia, 'Times New Roman', Times, serif;">论文</a></span>
          </li>
          <li class="person-intro-detail">
            <details>
              <summary style="color:var(--text-primary);cursor:pointer;">简介</summary>
              <p style="color:var(--text-muted);">这里收录优秀论文，格式统一为PDF，字数>5000</p>
              <script>print_essays();</script>
            </details>
          </li>
        </ul>
      </div>
      <div class="sign-container" style="flex:1;">
        <ul class="column_box" id="like-box">
          <li class="column-title">
            <span class="at-sort b-b-ece fl"><a class="at-sort-comment-a c-666 fl" style="font-family: Georgia, 'Times New Roman', Times, serif;">资料</a></span>
          </li>
          <li class="person-intro-detail">
            <p style="color:var(--text-primary);line-height:2;">
              文件备案 历史资料 马恩列斯毛著作文选/全集和各时期著作[PDF]<br>
              <a href="https://www.aliyundrive.com/s/QXuNy5c7sQz">点此获取</a><br>
              文件备案 历史资料 《红旗》1958-1976 汇总[PDF]<br>
              <a href="https://www.aliyundrive.com/s/4LuDRBQxLT8">点此获取</a><br>
              文件备案 历史资料 千禧年后社会调研分析报告[PDF]<br>
              <a href="https://www.aliyundrive.com/s/aJvXeStg1wK">点此获取</a>
            </p>
            <p style="text-align:right;color:var(--text-light);font-size:12px;">基于 Aliyundrive</p>
          </li>
        </ul>
      </div>
    </div>
  </article>
</div>
<style>
  .sort-btn { cursor:pointer;border:none;padding:3px 12px;border-radius:12px;font-size:12px;transition:all 0.3s ease; }
  .sort-btn:hover { transform:translateY(-1px); }
  #article-list li { animation: fadeIn 0.3s ease both; }
  #article-list li:nth-child(1) { animation-delay: 0.02s; }
  #article-list li:nth-child(2) { animation-delay: 0.04s; }
  #article-list li:nth-child(3) { animation-delay: 0.06s; }
  #article-list li:nth-child(4) { animation-delay: 0.08s; }
  #article-list li:nth-child(5) { animation-delay: 0.10s; }
  #article-list li:nth-child(6) { animation-delay: 0.12s; }
  #article-list li:nth-child(7) { animation-delay: 0.14s; }
  #article-list li:nth-child(8) { animation-delay: 0.16s; }
  #article-list li:nth-child(9) { animation-delay: 0.18s; }
  #article-list li:nth-child(10) { animation-delay: 0.20s; }
  @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
</style>
<script>
  var sortKey = 'time';
  var sortAsc = false;
  var artArticles = artmenu.filter(function(a){ return a.type === 'art'; });

  function sortArticles(key) {
    sortKey = key;
    ['time','name','author'].forEach(function(k){
      var btn = document.getElementById('sort-'+k);
      if (!btn) return;
      btn.style.background = (k === key) ? 'var(--text-link)' : 'var(--bg-secondary)';
      btn.style.color = (k === key) ? '#fff' : 'var(--text-primary)';
    });
    applySort();
  }

  function toggleOrder() {
    sortAsc = !sortAsc;
    var btn = document.getElementById('sort-asc');
    if (btn) btn.innerHTML = sortAsc ? '↑ 正序' : '↓ 倒序';
    applySort();
  }

  function applySort() {
    // If search results are showing, re-sort them in place
    var div3 = document.getElementById('3');
    if (div3 && div3.innerHTML.trim()) {
      reSortSearchResults();
      return;
    }
    // Otherwise re-sort the full list
    renderList();
  }

  function sortData(arr) {
    return arr.slice().sort(function(a, b){
      var va, vb;
      if (sortKey === 'time') { va = a.time; vb = b.time; }
      else if (sortKey === 'name') { va = a.name; vb = b.name; }
      else { va = a.author; vb = b.author; }
      if (sortAsc) return va > vb ? 1 : -1;
      else return va < vb ? 1 : -1;
    });
  }

  function buildListHTML(arr) {
    var h = '<li class=\"column-title\"><span class=\"at-sort b-b-ece fl\"><a class=\"at-sort-comment-a c-666 fl\" style=\"font-family:Georgia,Times New Roman,Times,serif;\">文章</a></span></li>';
    var inity = 2020;
    for (var i = 0; i < arr.length; i++) {
      var date = arr[i].time.split('-');
      if (parseInt(date[0]) > inity) { inity = parseInt(date[0]); h += '<li class=\"person-intro-detail gradient-text\">'+inity+'</li>'; }
      h += '<li class=\"person-intro-detail\"><span class=\"date\">'+date[1]+'-'+date[2]+' </span><a href=\"'+arr[i].links+'\" class=\"title\">'+arr[i].name+'</a></li>';
    }
    return h;
  }

  function renderList() {
    var sorted = sortData(artArticles);
    var container = document.getElementById('article-list');
    if (!container) {
      var div1 = document.getElementById('1');
      if (!div1) return;
      clearcontent('1');
      clearcontent('3');
      div1.innerHTML = '<ul id=\"article-list\" style=\"list-style:none;padding:12px 0;\"></ul>';
      container = document.getElementById('article-list');
    }
    if (!container) return;
    container.innerHTML = buildListHTML(sorted);
  }

  function reSortSearchResults() {
    // Re-trigger search - the results respect current sortKey/sortAsc via callback
    var str = document.getElementById('inpele').value.trim();
    if (!str) { renderList(); return; }
    var terms = str.split(/\\s+/);
    var ifcan = new Array(artmenu.length);
    for (var i = 0; i < artmenu.length; i++) ifcan[i] = (searchmode === 1);
    if (searchmode === 1) {
      for (var i = 0; i < artmenu.length; i++) {
        for (var j = 0; j < terms.length; j++) {
          if (!(artmenu[i].time.indexOf(terms[j]) !== -1 || artmenu[i].name.indexOf(terms[j]) !== -1 || artmenu[i].author.indexOf(terms[j]) !== -1)) ifcan[i] = false;
        }
      }
    } else {
      for (var i = 0; i < artmenu.length; i++) ifcan[i] = false;
      for (var i = 0; i < artmenu.length; i++) {
        for (var j = 0; j < terms.length; j++) {
          if (artmenu[i].time.indexOf(terms[j]) !== -1 || artmenu[i].name.indexOf(terms[j]) !== -1 || artmenu[i].author.indexOf(terms[j]) !== -1) ifcan[i] = true;
        }
      }
    }
    var results = [];
    for (var i = 0; i < artmenu.length; i++) { if (ifcan[i]) results.push(artmenu[i]); }
    results = sortData(results);
    var div3 = document.getElementById('3');
    if (div3) {
      clearcontent('1');
      var h = '<ul style=\"list-style:none;padding:12px 0;\"><li class=\"person-intro-detail\"><h2 style=\"text-align:center\">\"'+terms.join(' ')+'\" ('+results.length+' 条)</h2><hr></li>';
      var inity = 2020;
      for (var i = 0; i < results.length; i++) {
        var date = results[i].time.split('-');
        if (parseInt(date[0]) > inity) { inity = parseInt(date[0]); h += '<li class=\"person-intro-detail gradient-text\">'+inity+'</li>'; }
        h += '<li class=\"person-intro-detail\"><span class=\"date\">'+date[1]+'-'+date[2]+' </span><a href=\"'+results[i].links+'\" class=\"title\">'+results[i].name+'</a></li>';
      }
      if (results.length === 0) h += '<li class=\"person-intro-detail\"><h3>无结果</h3></li>';
      h += '</ul>';
      div3.innerHTML = h;
    }
  }

  // Initial render
  renderList();
</script>
