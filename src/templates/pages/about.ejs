              <div id="w3" style="font-family: 'Times New Roman', Times, serif;width: 14.2%;height:50px;float: left;text-align: center;font-size: large;color: var(--text-primary);">T</div>
              <div id="w4" style="font-family: 'Times New Roman', Times, serif;width: 14.2%;height:50px;float: left;text-align: center;font-size: large;color: var(--text-primary);">W</div>
              <div id="w5" style="font-family: 'Times New Roman', Times, serif;width: 14.2%;height:50px;float: left;text-align: center;font-size: large;color: var(--text-primary);">T</div>
              <div id="w6" style="font-family: 'Times New Roman', Times, serif;width: 14.2%;height:50px;float: left;text-align: center;font-size: large;color: var(--text-primary);">F</div>
              <div id="w7" style="font-family: 'Times New Roman', Times, serif;width: 14.2%;height:50px;float: left;text-align: center;font-size: large;color: var(--text-primary);">S</div>
            </div>
            <div id="calendar-dates">
              <div id="calendar-dates-container"></div>
              <script>
                var monthlist = ["January","February","March","April","May","June","July","August","September","October","November","December"];
                var myDate = new Date();
                var strDate = myDate.getFullYear()+'-'+(myDate.getMonth()+1)+'-1';
                var firstDate = new Date(strDate);
                var weekday = firstDate.getDay();
                var tmpDate = new Date(strDate);
                var datesContainer = document.getElementById("calendar-dates-container");
                for(var i = 0;i<weekday;i++){
                  var emptyDiv = document.createElement("div");
                  emptyDiv.className = "calendar-date";
                  emptyDiv.style.cssText = "width:14.2%;height:80px;float:left;margin-top:5px;font-size:large;color: var(--text-primary);";
                  datesContainer.appendChild(emptyDiv);
                }
                document.getElementById("calendar-title").innerHTML = monthlist[myDate.getMonth()];
                var daysInMonth = new Date(myDate.getFullYear(), myDate.getMonth()+1, 0).getDate();
                for(var j = 1;j<=daysInMonth;j++){
                  var dateDiv = document.createElement("div");
                  dateDiv.className = "calendar-date";
                  dateDiv.style.cssText = "width:14.2%;height:80px;float:left;margin-top:5px;font-size:large;text-align:center;color: var(--text-primary);";
                  dateDiv.innerHTML = j;
                  if(j == myDate.getDate()){
                    dateDiv.style.backgroundColor = "rgb(67, 87, 255)";
                    dateDiv.style.color = "white";
                    dateDiv.style.borderRadius = "40px";
                  }
                  datesContainer.appendChild(dateDiv);
                }
              </script>
            </div>
          </div>
        </div>
