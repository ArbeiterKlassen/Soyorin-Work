<div class="headpage"><div class="headpage-cover"></div></div>
<section class="main"<%- hasToc ? ' style="display:flex;justify-content:center;align-items:flex-start;gap:20px;"' : '' %>>
  <div class="left-box"<%- hasToc ? ' style="flex:0 0 auto;width:830px;float:none;margin:0;"' : '' %>>
    <div class="article-container">
      <div class="article-content markdown-body">
        <%- content %>
      </div>
    </div>
  </div>
  <% if (hasToc) { %>
  <aside class="toc" style="flex:0 0 250px;position:sticky;top:60px;max-height:calc(100vh - 80px);overflow-y:auto;font-size:13px;background:var(--bg-card);border-radius:10px;padding:14px 16px;box-shadow:var(--shadow-card);z-index:40;">
    <ul id="toc-list">
      <li><a href="#" id="toc-a-on">目录</a></li>
    </ul>
  </aside>
  <% } %>
</section>
<% if (hasToc) { %>
<script>
(function(){
  var headings = document.querySelectorAll('.article-content h1, .article-content h2, .article-content h3');
  var tocList = document.getElementById('toc-list');
  if(!tocList || headings.length === 0) return;
  tocList.innerHTML = '';
  headings.forEach(function(h, i){
    var id = 'heading-' + i;
    h.id = id;
    var level = parseInt(h.tagName.charAt(1));
    var indent = '   '.repeat(level - 1);
    tocList.innerHTML += '<li style="padding-left:' + ((level-1)*12) + 'px;"><a href="#' + id + '">' + indent + h.textContent + '</a></li>';
  });
})();
</script>
<% } %>
